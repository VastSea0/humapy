// Türkçe Karakter Desteği Testi

değişkenimiz = "merhaba" olsun
çalışıyor_mu = 1 olsun
öğrenci_sayısı = 120 olsun
ışık_hızı = 300000 olsun
şemsiye = "açık" olsun
üretim_tarihi = 2024 olsun

değişkenimiz'i yazdır;
çalışıyor_mu ise {
    "Türkçe karakterli değişkenler çalışıyor!"'u yazdır;
}

toplam fonksiyon olsun sayı_bir, sayı_iki alsın {
    sayı_bir + sayı_iki'yi döndür
}

yük_miktarı = toplam(öğrenci_sayısı, 80) olsun
"Toplam yük: " + yük_miktarı'nı yazdır;

// Kesme işareti ve ek desteği
öğrenci_sayısı'nı 200 ile karşılaştır:
öğrenci_sayısı < 200 ise {
    "Kapasite yeterli."'yi yazdır;
}

// Sınıf ve Nesne
kişi sınıf olsun {
    adı = "" olsun
    yaşı = 0 olsun
    tanıt fonksiyon olsun {
        "Ben " + kendisi'nin adı + ", " + kendisi'nin yaşı + " yaşındayım."'nı yazdır;
    }
}

öğrenci = kişi() olsun
öğrenci'nin adı = "Egehan" olsun
öğrenci'nin yaşı = 17 olsun
öğrenci.tanıt()
