{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "huma-ide",
  "version": "0.2.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../ide/public",
    "devUrl": "http://localhost:3737",
    "beforeDevCommand": "npm start --prefix ../ide",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hüma IDE",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
