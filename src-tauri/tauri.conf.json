{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "huma-ide",
  "version": "0.2.0",
  "identifier": "com.vastsea.humaide",
  "build": {
    "frontendDist": "../ide/dist",
    "devUrl": "http://localhost:3737",
    "beforeDevCommand": "cd ../ide && npm run dev",
    "beforeBuildCommand": "cd ../ide && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hüma IDE",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
